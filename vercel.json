{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm install --legacy-peer-deps --no-audit --no-fund",
  "buildCommand": "npm run build",
  "regions": ["iad1"],
  "functions": {
    "app/api/identify/route.ts": { "maxDuration": 30 },
    "app/api/car-info/route.ts": { "maxDuration": 30 },
    "app/api/debug-claude/route.ts": { "maxDuration": 30 },
    "app/api/webhook/stripe/route.ts": { "maxDuration": 15 }
  }
}
