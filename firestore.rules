// CarSpotter Firestore Security Rules
//
// Paste into Firebase Console → Firestore Database → Rules tab → Publish.
// These rules require sign-in for all writes and scope every user to
// only their own data.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── /users/{uid} — profile + plan ──
    match /users/{uid} {
      // Anyone signed-in can read their own profile.
      allow read: if request.auth != null && request.auth.uid == uid;
      // Only the owner can create/update their profile.
      // The "plan" field can only be set to: free, spotter, collector, concours.
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && (!('plan' in request.resource.data)
            || request.resource.data.plan in ['free', 'spotter', 'collector', 'concours']);
      // No client-side deletes.
      allow delete: if false;
    }

    // ── /scans/{scanId} — identified cars ──
    match /scans/{scanId} {
      // Read: only the owner.
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      // Create: must be signed-in, must set userId to themselves.
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      // Update / delete: only the owner.
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // ── /spots/{spotId} — community-contributed locations ──
    // Anyone signed in can read. Submissions write to /spotSubmissions
    // for admin review (not yet wired in code).
    match /spots/{spotId} {
      allow read: if request.auth != null;
      allow write: if false; // admin-only via service account
    }

    match /spotSubmissions/{subId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ── /posts/{postId} — global social feed ──
    match /posts/{postId} {
      // PUBLIC read — anyone (signed-in or not) can see the feed.
      allow read: if true;

      // Create: must be signed in, must set userId to themselves,
      // must include the required fields.
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['userId','make','model','photoUrl','createdAt']);

      // Updates: only the like array can be modified by other users;
      // the post owner can modify anything except userId/createdAt.
      allow update: if request.auth != null && (
        // Owner updating their own post (but not userId / createdAt)
        (resource.data.userId == request.auth.uid
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.createdAt == resource.data.createdAt
        )
        // OR anyone toggling their own like
        || (request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['likedBy'])
            && request.auth.uid in
                 request.resource.data.likedBy.toSet()
                   .union(resource.data.likedBy.toSet())
                   .difference(
                     request.resource.data.likedBy.toSet()
                       .intersection(resource.data.likedBy.toSet())))
      );

      // Delete: only the post owner.
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }
  }
}
